# ANJIR Agro Platform — Environment Variables
# Copy this file to .env and fill in your values

# ─────────────────────────────────────────────
# DATABASE
# ─────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:@localhost:5432/anjir_agro"

# ─────────────────────────────────────────────
# NEXTAUTH
# ─────────────────────────────────────────────
NEXTAUTH_SECRET="your-super-secret-key-minimum-32-characters-long"
NEXTAUTH_URL="http://localhost:3000"

# ─────────────────────────────────────────────
# GOOGLE OAUTH (для входа администраторов)
# https://console.cloud.google.com → APIs → Credentials → OAuth Client ID
# Redirect URI: http://localhost:3000/api/auth/callback/google
# ─────────────────────────────────────────────
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ─────────────────────────────────────────────
# TELEGRAM BOT
# Создать бота: @BotFather → /newbot
# Получить Chat ID: https://api.telegram.org/bot<TOKEN>/getUpdates
# ─────────────────────────────────────────────
TELEGRAM_BOT_TOKEN="1234567890:ABCdefGhIjKlmNopQrStUvWxYz"
TELEGRAM_ADMIN_CHAT_ID="123456789"
TELEGRAM_WEBHOOK_SECRET="any-random-string-for-webhook-security"
